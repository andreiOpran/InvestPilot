# To use: cp k8s/go-secrets.example k8s/go-secrets.yaml, fill in values, then: make k8s-apply-secret-go

apiVersion: v1
kind: Secret
metadata:
  name: go-secrets
  namespace: investpilot
type: Opaque
data:
  # All values must be base64 encoded: echo -n "your-value" | base64

  # PostgreSQL connection string (Supabase or self-hosted)
  DATABASE_URL: <base64-encoded>

  # 32-byte hex key for AES encryption
  AES_MASTER_KEY: <base64-encoded>

  # Random secret for signing JWTs
  JWT_SECRET: <base64-encoded>

  # Stripe secret key (sk_live_... or sk_test_...)
  STRIPE_SECRET_KEY: <base64-encoded>

  # Stripe webhook signing secret (whsec_...)
  STRIPE_WEBHOOK_KEY: <base64-encoded>

  # Cloudflare Turnstile secret key
  TURNSTILE_SECRET_KEY: <base64-encoded>

  # RabbitMQ connection string (amqps://... or amqp://...)
  RABBITMQ_URL: <base64-encoded>

  # Email address for SMTP test destination
  SMTP_TEST_DESTINATION: <base64-encoded>

  # Random 64-char hex secret for internal endpoint auth
  INTERNAL_ENDPOINT_SECRET: <base64-encoded>

  # "true" or "false" — enable/disable cron jobs
  ENABLE_CRON: <base64-encoded>

  # Cookie domain (e.g. investpilot.live)
  COOKIE_DOMAIN: <base64-encoded>

  # "true" or "false" — secure cookie flag
  COOKIE_SECURE: <base64-encoded>

  # Frontend base URL (e.g. https://investpilot.live)
  FRONTEND_BASE_URL: <base64-encoded>

  # Email provider: "resend" or "smtp"
  EMAIL_PROVIDER: <base64-encoded>

  # Resend API key (re_...)
  RESEND_API_KEY: <base64-encoded>
