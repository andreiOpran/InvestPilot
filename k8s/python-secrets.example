# To use: cp k8s/python-secrets.example k8s/python-secrets.yaml, fill in values, then: make k8s-apply-secret-python

apiVersion: v1
kind: Secret
metadata:
  name: python-secrets
  namespace: investpilot
type: Opaque
data:
  # All values must be base64 encoded: echo -n "your-value" | base64

  # PostgreSQL connection string (must match go-secrets DATABASE_URL)
  DATABASE_URL: <base64-encoded>

  # RabbitMQ connection string (must match go-secrets RABBITMQ_URL)
  RABBITMQ_URL: <base64-encoded>
