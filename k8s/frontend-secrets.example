# To use: cp k8s/frontend-secrets.example k8s/frontend-secrets.yaml, fill in values, then: make k8s-apply-secret-frontend

apiVersion: v1
kind: Secret
metadata:
  name: frontend-secrets
  namespace: investpilot
type: Opaque
data:
  # All values must be base64 encoded: echo -n "your-value" | base64

  # Stripe publishable key (pk_live_... or pk_test_...)
  VITE_STRIPE_PUBLISHABLE_KEY: <base64-encoded>

  # Cloudflare Turnstile site key
  # Use 1x00000000000000000000AA for local testing (always passes)
  VITE_TURNSTILE_SITE_KEY: <base64-encoded>
