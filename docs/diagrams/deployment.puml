@startuml InvestPilot-Deployment

top to bottom direction

actor "Investor" as Investor

cloud "Cloudflare Edge" as CF {
    component "TLS Termination · CDN · DDoS\ninvestpilot.live" as CDN
}


rectangle "DigitalOcean - K3s Cluster" as K3S {

    node "vps-1 · k3s-master · 1vCPU 2GB" as VPS1 {
        component "K3s Control Plane\nAPI Server · Scheduler · Controller Manager · etcd" as ControlPlane
        component "Traefik Ingress Controller\n:443 websecure" as Traefik
    }

    rectangle "Worker Nodes · k3s-worker-1 · k3s-worker-2\nK8s-scheduled workloads" as Workers {
        component "Go Operational Node\n2 replicas · nodeAffinity: not k3s-master\nK8s-scheduled across workers · :8081 /metrics" as Go
        component "Nginx · React SPA · 1 replica · K8s-scheduled · :80" as Nginx
        component "Python Decisional Node\n1 replica · nodeSelector: k3s-worker-2\n:9090 /metrics" as Python
    }

    rectangle "K8s CronJobs - namespace: investpilot" as CJ {
        artifact "cron-pipeline-daily\ndaily · 22:00 UTC" as CronD
        artifact "cron-pipeline-intraday\nevery 15 min" as CronI
        artifact "cron-rebalance\nmonthly · 1st · 02:00 UTC" as CronR
        artifact "cron-cleanup\ndaily · 03:00 UTC" as CronC
    }

    rectangle "Grafana Agent DaemonSet - namespace: monitoring\n1 pod per node · k3s-master · k3s-worker-1 · k3s-worker-2" as Mon {
        component "Grafana Agent (Alloy)\nkube-state-metrics · node-exporter" as Agent
    }

}

node "Stripe\nPayment Sandbox" as StripeExt
node "Yahoo Finance\nyfinance" as YFin
node "Resend\nTransactional Email API" as ResendExt

database "Supabase\nManaged PostgreSQL\nsession mode · :5432" as PG
database "CloudAMQP\nManaged RabbitMQ\ncmd_queue (durable)" as AMQP

cloud "Grafana Cloud" as GCloud {
    component "Prometheus · Grafana\nAlertmanager" as GCInner
}

' AMQP at bottom
' Python -[hidden]-> AMQP
' GCloud at bottom
Mon -[hidden]-> GCloud
Go -[hidden]-> GCloud

Investor -right-> CDN : HTTPS
CDN --> Traefik : HTTPS / origin cert
Traefik --> Nginx : "/* → :80"
Traefik --> Go : "/api /internal → :8081"
CronD --> Go : "POST /internal/* + X-Internal-Secret"
CronI --> Go
CronR --> Go
CronC --> Go
Go --> AMQP : AMQP publish
Python --> AMQP : "AMQP consume · RPC reply"
Go --> PG : TCP / DDL+DML
Python --> PG : TCP / DML only
Go --> StripeExt : HTTPS
Python --> YFin : HTTPS
Agent --> Go : scrape :8081/metrics
Agent --> Python : scrape :9090/metrics
Agent --> GCInner : remote_write HTTPS
Go --> ResendExt : HTTPS
' ResendExt -[hidden]-> StripeExt


@enduml
