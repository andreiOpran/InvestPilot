@startuml InvestPilot-C4-L2
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_LANDSCAPE()

Person(investor, "Investor", "Monitors investments and manages cash flow. Portfolio allocation is handled automatically by the platform.")

System_Ext(cloudflare, "Cloudflare", "CDN and TLS proxy. Sits in the request path in front of the frontend.")
System_Ext(stripe, "Stripe", "Payment processing (Sandbox mode)")
System_Ext(yfinance, "Yahoo Finance", "ETF historical closing prices fetched via yfinance library")
System_Ext(mailer, "Email Provider", "Resend API (prod) / Gmail SMTP (local dev). Sends email verification, password reset, deposit confirmation and account lockout alerts.")

System_Boundary(investpilot, "InvestPilot") {

    Container(spa, "React Frontend", "React 19 + TypeScript + Vite", "Single-Page Application. Portfolio dashboard, forecast, auth flows, onboarding, settings. JWT auth.")

    Container(operational, "Operational Node", "Go + Gin + GORM", "Core REST API. Auth and IAM (JWT, 2FA, sessions), wallet deposit/cashout, portfolio invest/sell, rebalance and forecast orchestration. Owns all DB schema via GORM AutoMigrate.")

    Container(decisional, "Decisional Node", "Python 3 + Pika", "Stateless math engine. Consumes RabbitMQ commands: CMD_SYNC_DAILY, CMD_SYNC_INTRADAY, CMD_GENERATE, CMD_REBALANCE_USER, CMD_FORECAST. Runs HRP, Monte Carlo simulation, yfinance sync (5y historical + 15-min intraday). Writes DML only, never DDL.")

    Container(scheduler, "Pipeline Scheduler", "K8s CronJob (prod) / GoCron (local dev)")

    Container(rabbitmq, "RabbitMQ", "CloudAMQP (managed)", "Async command bus. Durable queue: cmd_queue. RPC pattern via correlation_id for synchronous commands like CMD_REBALANCE_USER.")

    ContainerDb(postgres, "PostgreSQL", "Supabase (managed)", "All persistent data. Go owns schema via GORM AutoMigrate. Python writes results via DML only.")
}

' Relationships
Rel_L(investor, cloudflare, "HTTPS request", "HTTPS")
Rel_U(cloudflare, spa, "Proxies and delivers SPA assets", "HTTPS")
Rel(spa, operational, "REST API calls", "HTTPS/JSON")
Rel(operational, rabbitmq, "Publishes commands (CMD_SYNC_DAILY, CMD_SYNC_INTRADAY, CMD_GENERATE, CMD_REBALANCE_USER, CMD_FORECAST)", "AMQP")
Rel(rabbitmq, decisional, "Delivers commands", "AMQP")
Rel(scheduler, operational, "Triggers pipeline and rebalance", "HTTP POST / in-process")
Rel(operational, postgres, "Read/Write", "TCP")
Rel(decisional, postgres, "Write results (DML only)", "TCP")
Rel(operational, stripe, "Create payment intent, verify webhook", "HTTPS")
Rel(decisional, yfinance, "Fetch 5y historical + 15-min intraday ETF data", "HTTPS")
Rel(operational, mailer, "Send transactional emails", "HTTPS (prod) / SMTP (dev)")

Lay_R(mailer, stripe)

@enduml
