DATABASE_URL=postgres://admin:pass@db:5432/robo_advisory
SMTP_TEST_DESTINATION=your-smtp-test-destination
AES_MASTER_KEY=your-aes-key
INTERNAL_ENDPOINT_SECRET=your-key-for_internal-endpoints
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_KEY=whsec_...


# Email provider: "smtp" (default, for dev) or "resend" (for production)
EMAIL_PROVIDER=smtp

# SMTP settings (used when EMAIL_PROVIDER=smtp)
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-access-token
SMTP_FROM=InvestPilot
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Resend settings (used when EMAIL_PROVIDER=resend)
RESEND_API_KEY=re_...
RESEND_FROM=InvestPilot <support@investpilot.live>