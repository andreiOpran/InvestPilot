@startuml C4_Container_RoboAdvisor
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

' TITLU DIAGRAMA
' title Diagrama C4 Container - Platforma Robo-Advisory

' DEFINIRE ACTORI SI SISTEME EXTERNE
Person(investor, "Utilizator", "Utilizator care doreste sa investeasca automatizat")
System_Ext(stripe_api, "Stripe Payment API (Sandbox)", "Sistem extern pentru simularea alimentarii contului cu bani")

' DEFINIREA SISTEMULUI PRINCIPAL SI A CONTAINERELOR SALE
System_Boundary(robo_system, "Platforma Robo-Advisory") {

    Container(spa_frontend, "Web Browser App (Frontend)", "HTML, Bootstrap, Plotly.js", "Randeaza interfata grafica si graficele in browserul utilizatorului")
    
    Container(go_server, "Nod Operational (API Gateway & Web Server)", "Golang (Gin Framework)", "Gestioneaza autentificarea, sesiunile, comunicarea cu platile si transmite paginile web")
    
    Container(python_worker, "Nod Decizional (Compute Engine)", "Python 3, Flask, Pandas, SciPy", "Microserviciu intern care executa algoritmi de optimizare (Markowitz), calcule de risc si procesare de date")
    
    ContainerDb(postgres_db, "Baza de Date", "PostgreSQL", "Stocheaza datele utilizatorilor, portofoliile curente, istoricul tranzactiilor si datele de piata")

}

' DEFINIREA RELATIILOR (FLUXURI DE DATE)

' 1. Utilizatorul interactioneaza cu browserul
Rel(investor, spa_frontend, "Vizualizeaza dashboard-uri, initiaza depuneri", "HTTPS")

' 2. Browserul vorbeste cu serverul principal
Rel(spa_frontend, go_server, "Trimite cereri de date, primeste HTML/JSON", "HTTPS/JSON")

' 3. Serverul Go vorbeste cu DB si Plati
Rel(go_server, postgres_db, "Citeste/Scrie balante si tranzactii", "TCP/IP")
Rel(go_server, stripe_api, "Initiaza plati simulate (Paper Trading)", "HTTPS/JSON")

' 4. COMUNICAREA CRITICA: Go cere calcule de la Python (RETEA PRIVATA)
Rel_D(go_server, python_worker, "Trimite cerere de optimizare portofoliu", "HTTP/JSON (Internal VPC)")

' 5. Python citeste datele necesare si returneaza rezultatul
Rel_U(python_worker, postgres_db, "Citeste date istorice pentru calcul", "TCP/IP")
Rel_U(python_worker, go_server, "Returneaza structura optima de portofoliu", "JSON")

@enduml